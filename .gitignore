# ──────────────────────────────────────────────────────────────────────────────
# SPECTRA — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Generated PDFs (npm run templates) ────────────────────────────────────────
generated-pdfs/

# ── Claude Code / IDE state ──────────────────────────────────────────────────
.claude/
.remember/

# ── Misc development files ───────────────────────────────────────────────────
AUDIT_REPORT.md
*.jpeg
spectra_gap_analysis.md.pdf

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ───────────────────────────────────────────────────────────────────
/.next/
/out/
/build/
next-env.d.ts

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production

# ── Audio files (never commit uploaded/processed audio) ───────────────────────
*.wav
*.mp3
*.flac
*.aiff
*.aif
*.ogg
*.m4a
*.aac
*.wma
*.opus

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
*.swp
*.swo
*~
.editorconfig

# ── Python (Modal workers) ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
dist/
*.egg

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage/
*.lcov
.nyc_output/

# ── Build artifacts ───────────────────────────────────────────────────────────
*.tsbuildinfo
*.js.map
*.d.ts.map

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Certificates & keys ──────────────────────────────────────────────────────
*.pem
*.key
*.cert
*.crt

# ── Deployment ────────────────────────────────────────────────────────────────
.vercel
.netlify

# ── Sentry ────────────────────────────────────────────────────────────────────
.sentryclirc

# ── Supabase local ────────────────────────────────────────────────────────────
supabase/.temp/
supabase/.branches/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
.cache/
