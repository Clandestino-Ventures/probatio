# ──────────────────────────────────────────────────────────────────────────────
# PROBATIO — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values.
# NEVER commit `.env.local` or any file containing real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription plan price IDs (create via Stripe Dashboard or setup-stripe script)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...

# Forensic product price IDs (one-time)
STRIPE_PRICE_FORENSIC_STANDARD=price_...
STRIPE_PRICE_FORENSIC_EXPERT=price_...

# ── Inngest (Pipeline Orchestration) ─────────────────────────────────────────
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ── Modal (GPU Compute) ──────────────────────────────────────────────────────
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret
# Alternative: single combined auth token (takes precedence over ID+SECRET)
MODAL_AUTH_TOKEN=
#
# ── Modal URL Architecture ──
# The TS client (src/lib/modal/client.ts) constructs: ${MODAL_BASE_URL}${endpointPath}
# where endpointPath comes from src/lib/modal/endpoints.ts (e.g. /api/normalize).
#
# All Modal functions are on the same app: "spectra-forensic-audio" (modal/config.py).
# Each @modal.web_endpoint() gets its own URL when deployed.
#
# How to deploy and get URLs:
#   1. cd modal && bash deploy.sh
#   2. Modal prints URLs for each function. They follow this pattern:
#      https://<workspace>--spectra-forensic-audio-<function-name>.modal.run
#
# Modal web endpoint function names (from modal/functions/*.py):
#   normalize_endpoint        → audio_normalize.py
#   separate_stems            → demucs_separation.py
#   extract_features_endpoint → feature_extraction.py
#   generate_embeddings_endpoint → clap_embeddings.py
#   fingerprint_endpoint      → fingerprint.py
#   extract_lyrics            → whisper_lyrics.py (via @app.function, not web_endpoint)
#
# MODAL_BASE_URL should be set to the app's shared prefix URL.
# If Modal routes all endpoints under one app URL, set:
#   MODAL_BASE_URL=https://yourworkspace--spectra-forensic-audio.modal.run
#
# If each function has its own subdomain (Modal default), you may need
# a reverse proxy, or modify src/lib/modal/endpoints.ts to use per-function URLs.
#
# For local development without GPU, set MODAL_MOCK=true (uses mock data)
MODAL_MOCK=true
MODAL_BASE_URL=
MODAL_ENDPOINT_URL=

# ── Anthropic (AI Analysis) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AcoustID (Audio Fingerprinting) ──────────────────────────────────────────
ACOUSTID_API_KEY=your-acoustid-api-key

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Monitoring & Analytics ───────────────────────────────────────────────────
# Sentry — https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=clandestino-ventures
SENTRY_PROJECT=spectra
# PostHog — https://app.posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Ed25519 Document Signing ─────────────────────────────────────────────────
# Generate with: npx tsx scripts/generate-signing-key.ts
PROBATIO_SIGNING_PRIVATE_KEY=your-private-key-base64
PROBATIO_SIGNING_PUBLIC_KEY=your-public-key-base64

# ── Cross-Venture Integrations ───────────────────────────────────────────────
# Musavox → Probatio: lyrics webhook
#   1. In Probatio: create an API key with 'integrations' permission
#   2. In Musavox: set PROBATIO_API_KEY=pk_live_... and
#      PROBATIO_WEBHOOK_URL=https://probatio.audio/api/integrations/musavox
#   Musavox calls the webhook after each successful transcription.
#
# Future: Musyn → Probatio (artist risk signals via /api/integrations/musyn)
#
# This is NOT shared auth — each venture has its own auth system.
# Cross-venture communication uses API keys + webhooks.

# ── Demo Mode ────────────────────────────────────────────────────────────────
# Set to "true" to populate the dashboard with realistic mock data (no backend required).
NEXT_PUBLIC_DEMO_MODE=true
